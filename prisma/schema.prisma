datasource db {
  provider  = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Category {
  id            String    @id @default(uuid())
  name          String
  slug          String    @unique
  imageUrl      String?
  displayOrder  Int       @default(0)
  products      Product[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Product {
  id            String      @id @default(uuid())
  name          String
  description   String      @db.Text
  shortDesc     String?     @db.VarChar(255)
  price         Decimal     @db.Decimal(10, 2)
  promoPrice    Decimal?    @db.Decimal(10, 2)
  categoryId    String
  category      Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images        String[]    // Array of image paths/URLs
  stock         Int         @default(0)
  unit          String      @default("unidade") // kg, saco 25kg, litro, etc.
  sku           String?     @unique
  active        Boolean     @default(true)
  featured      Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orderItems    OrderItem[]
}

model AdminUser {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String   // Hash bcrypt
  role      String   @default("admin") // admin, operator
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Order {
  id            String      @id @default(uuid())
  clientName    String
  clientPhone   String
  clientEmail   String?
  street        String
  number        String
  complement    String?
  neighborhood  String
  city          String      @default("Itu")
  state         String      @default("SP")
  zipCode       String
  paymentMethod String      // pix, money, card_on_delivery
  subtotal      Decimal     @db.Decimal(10, 2)
  deliveryFee   Decimal     @db.Decimal(10, 2) @default(0)
  total         Decimal     @db.Decimal(10, 2)
  status        OrderStatus @default(NEW)
  notes         String?     @db.Text
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]
  customerId    String?
  customer      Customer?   @relation(fields: [customerId], references: [id])
}

model Customer {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  password     String
  phone        String
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String    @default("Itu")
  state        String    @default("SP")
  zipCode      String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  orders       Order[]
}

enum OrderStatus {
  NEW
  CONFIRMED
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  productName String? // Snapshot do nome do produto no momento da compra
  quantity    Int
  price       Decimal @db.Decimal(10, 2)
}
